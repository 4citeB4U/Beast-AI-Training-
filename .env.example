# VITE_VOICE_WS_URL: LeeWay-Edge-RTC voice websocket endpoint.
# Example local endpoint when running the RTC service on this machine.
VITE_VOICE_WS_URL="ws://localhost:3000/ws"

# VITE_ENABLE_RTC_CAMERA: Enable Agent Lee camera vision feed integration.
VITE_ENABLE_RTC_CAMERA="true"

# VITE_LEEWAY_RTC_SDK_ENTRY: Optional explicit SDK source base override.
# Use this when npm git packaging does not expose the expected runtime modules.
# Example: VITE_LEEWAY_RTC_SDK_ENTRY="/.tmp-leeway-edge-rtc/src"
VITE_LEEWAY_RTC_SDK_ENTRY=""

# VITE_BACKEND_URL: Backend OAuth gateway and learner service endpoint
# Required for authentication flow (populates frontend API calls)
VITE_BACKEND_URL="http://localhost:3000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowArbitraryExtensions": true,
    "types": ["vite/client"]
  },
  "include": [
    "vite-env.d.ts",
    "components/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
